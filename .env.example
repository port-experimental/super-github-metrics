# =============================================================================
# Port.io Configuration (Required)
# =============================================================================
PORT_CLIENT_ID=your_port_client_id
PORT_CLIENT_SECRET=your_port_client_secret
PORT_BASE_URL=https://api.getport.io/v1

# Optional: Use bearer token instead of client credentials
# PORT_BEARER_TOKEN=your_port_bearer_token

# =============================================================================
# GitHub Configuration (Required)
# =============================================================================

# Comma-separated list of GitHub organizations to fetch metrics from
X_GITHUB_ORGS=org1,org2

# -----------------------------------------------------------------------------
# GitHub Authentication (Choose ONE method)
# -----------------------------------------------------------------------------

# Option 1: Personal Access Token(s) - comma-separated for multiple tokens
X_GITHUB_TOKEN=ghp_your_token_here

# Option 2: GitHub App Authentication (all three are required if using this method)
# X_GITHUB_APP_ID=123456
# X_GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# X_GITHUB_APP_INSTALLATION_ID=12345678

# Optional: GitHub Enterprise domain (omit for github.com)
# X_GITHUB_ENTERPRISE=github.mycompany.com

# =============================================================================
# Coder Configuration (Optional - only if using Coder integration)
# =============================================================================
# CODER_SESSION_TOKEN=your_coder_session_token
# CODER_API_BASE_URL=https://coder.example.com
# CODER_ORGANIZATION_ID=your_coder_org_id

# =============================================================================
# Logging Configuration (Optional)
# =============================================================================

# Log level: trace, debug, info, warn, error, fatal (default: info)
# PINO_LOG_LEVEL=info

# Log format: set to "pretty" for human-readable logs with colors
# PINO_LOG_FORMAT=pretty

# =============================================================================
# Processing Configuration (Optional)
# =============================================================================

# Force reprocessing of all users' onboarding metrics, even those already processed (default: false)
# Useful when recalculating metrics after fixing bugs or changing calculation logic
# FORCE_ONBOARDING_METRICS=true

# Batch size for onboarding metrics processing (default: 3)
# ONBOARDING_BATCH_SIZE=3

# =============================================================================
# Port Blueprint Configuration (Optional)
# =============================================================================

# Target blueprint for service metrics (default: service)
# PORT_SERVICE_BLUEPRINT=service

# Target blueprint for time-series metrics (default: serviceMetrics)
# PORT_SERVICE_METRICS_BLUEPRINT=serviceMetrics
